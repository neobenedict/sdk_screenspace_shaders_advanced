screenspace_general
{
    $pixshader "demo_spinning_split_ps20"

    $basetexture "_rt_FullFrameFB"
    $texture1    "_rt_Camera"
    $texture2    ""
    $texture3    ""

    $x360appchooser 1
    $ignorez        1
    $fix_fb         32768

    "<dx90"
    {
        $no_draw 1
    }

    $copyalpha                 1
    $alpha_blend_color_overlay 0
    $alpha_blend               0
    $linearwrite               1
    $linearread_basetexture    1
    $linearread_texture1       1
    $linearread_texture2       0
    $linearread_texture3       0

    // ── Constants0 ──────────────────────────────
    $c0_x 0.0   // time (CurrentTime proxy — drives rotation)
    $c0_y 0.0   // viewmodel rejection epsilon
    $c0_z -32   // floor Z

    // ── Constants1 ──────────────────────────────
    $c1_x 200048.0  // ceiling Z (very large = infinite)
    $c1_y 992.0     // wall half-width (square arena, X and Y)
    $c1_z 30.0      // gap half-width in world units

    // ── Constants2 (player position, proxy-driven) ──
    $c2_x 0.0
    $c2_y 0.0
    $c2_z 0.0
    $pos   "[0 0 0]"
    $zero  0.0

    Proxies
    {
        // Rotation: 1 rev/sec via CurrentTime
        LinearRamp
        {
            resultVar $c0_x
            rate 0.4
initialVAlue 10
        }

        // Framebuffer fix
        Equals
        {
            srcVar1    $fix_fb
            resultVar  $flags2
        }

        // Player position
        PlayerPosition
        {
            scale      1
            resultVar  "$pos"
        }
        Clamp
        {
            srcVar1    $zero
            min        "$pos[0]"
            max        "$pos[0]"
            resultVar  $c2_x
        }
        Clamp
        {
            srcVar1    $zero
            min        "$pos[1]"
            max        "$pos[1]"
            resultVar  $c2_y
        }
        Clamp
        {
            srcVar1    $zero
            min        "$pos[2]"
            max        "$pos[2]"
            resultVar  $c2_z
        }
    }
}
